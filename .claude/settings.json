{
  "permissions": {
    "allow": [
      "PowerShell(supabase db push)",
      "PowerShell(npx supabase db push 2>&1)",
      "Bash(npx supabase *)",
      "Bash(Select-Object -First 5)",
      "Bash(npx skills add *)",
      "Read(//c/Users/user/AppData/Roaming/Code/User/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/check-gstack.sh\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "ralph-loop@claude-plugins-official": true
  }
}
