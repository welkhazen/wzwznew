filters:
  and:
    - file.hasTag("work-note")
    - file.ext == "md"
    - '!file.inFolder("templates")'
formulas:
  quarter: if(date, "Q" + ((date(date).month - 1) / 3 + 1).floor().toString() + " " + date(date).year.toString(), "")
  age_days: if(date, (today() - date(date)).days, "")
properties:
  file.name:
    displayName: Note
  status:
    displayName: Status
  project:
    displayName: Project
  formula.quarter:
    displayName: Quarter
  date:
    displayName: Date
  description:
    displayName: Summary
views:
  - type: table
    name: Active Work
    filters:
      and:
        - status == "active"
    groupBy:
      property: project
      direction: ASC
    order:
      - file.name
      - date
      - project
      - formula.quarter
      - description
  - type: table
    name: All by Quarter
    groupBy:
      property: formula.quarter
      direction: DESC
    order:
      - file.name
      - date
      - status
      - project
      - description
  - type: table
    name: Completed
    filters:
      and:
        - status == "completed"
    groupBy:
      property: formula.quarter
      direction: DESC
    order:
      - file.name
      - date
      - project
      - formula.quarter
      - description
