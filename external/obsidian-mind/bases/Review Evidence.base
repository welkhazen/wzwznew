filters:
  and:
    - file.inFolder("perf/evidence")
    - file.ext == "md"
properties:
  file.name:
    displayName: Evidence
  person:
    displayName: Person
  cycle:
    displayName: Cycle
  date:
    displayName: Date
  description:
    displayName: Summary
views:
  - type: table
    name: By Cycle
    groupBy:
      property: cycle
      direction: DESC
    order:
      - file.name
      - person
      - cycle
      - date
      - description
  - type: table
    name: By Person
    groupBy:
      property: person
      direction: ASC
    order:
      - file.name
      - person
      - cycle
      - date
      - description
